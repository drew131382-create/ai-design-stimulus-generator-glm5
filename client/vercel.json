{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://ai-design-stimulus-generator-glm5-api.onrender.com/api/$1"
    },
    {
      "source": "/health",
      "destination": "https://ai-design-stimulus-generator-glm5-api.onrender.com/health"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
